  "keyFeatures": [
    "84+ battle-tested technical indicators (moving averages, oscillators, channels, volume, candlestick patterns)",
    "Three indicator styles: Series (batch), BufferList (incremental), and StreamHub (real-time observable)",
    "Indicator chaining — compute indicators of indicators (e.g., RSI of OBV)",
    "Custom indicator support via IReusable interface",
    "Targets .NET 8, 9, and 10 with sub-millisecond per-quote latency",
    "Custom quote class support via IQuote interface",
    "Automatic warmup/pruning with RemoveWarmupPeriods utility",
    "Thread-safe StreamHub with rollback for late-arriving or corrected data"
  ],
  "publicApiSurface": [
    "Quote (IQuote) — OHLCV input model",
    "IReadOnlyList<TResult> quotes.To{Indicator}(...) — Series batch extension methods",
    "{Indicator}List — BufferList incremental ICollection classes",
    "QuoteHub / {Indicator}Hub — StreamHub observable classes",
    "CandlePart enum — alternate price variants (HL2, HLC3, OHL3, etc.)",
    "IReusable interface — enables custom chainable indicators",
    "RemoveWarmupPeriods() — result utility extension",
    "Find(DateTime) — result lookup utility",
    "Condense() — candlestick result filter utility",
    "ToSortedList() / Validate() — quote utility extensions",
    "IndicatorCatalog — programmatic metadata access for all indicators"
  ]
}
